# Fleet Dispatcher — ApiLogicServer environment (copy to /etc/fleet-dispatcher/api.env)
# chmod 600 — contains the JWT secret and DB credentials.

# Turn security ON (ALS defaults it OFF).
SECURITY_ENABLED=true

# JWT signing secret — MUST match the realtime/ bridge's FLEET_JWT_SECRET.
SECRET_KEY=change-me-to-a-long-random-secret

# Fleet database (ALS reflects the `fleet` schema; role search_path = fleet,public).
SQLALCHEMY_DATABASE_URI=postgresql://fleet:fleet@localhost:5432/fleet_dispatcher

# Serve on 5659 (also passed positionally in ExecStart).
APILOGICSERVER_PORT=5659

# Realtime producer (optional) — enables ALS → Kafka events for the bridge.
# Leave unset to run without realtime.
# KAFKA_CONNECT={"bootstrap.servers": "localhost:9092"}
