<?xml version="1.0" encoding="UTF-8" ?>
<!--
  Wt server configuration for the dispatcher console + HUD.

  WebSockets are enabled so server push (CommBus comms + HudControlBus) is
  delivered over a persistent socket instead of long-polling — this is what
  makes the comms rail update in real time. Run the app with:

    ./fleet_dispatcher_desktop --docroot . --http-listen 0.0.0.0:8080 \
        -c wt_config.xml

  See docs/DISPATCHER_DESKTOP.md.
-->
<server>
  <application-settings location="*">
    <!-- Real-time server push transport. -->
    <web-sockets>true</web-sockets>

    <!-- Server push needs sessions kept alive while a socket is open. -->
    <session-management>
      <dedicated-process>
        <max-num-sessions>100</max-num-sessions>
      </dedicated-process>
    </session-management>

    <!-- Keep idle pushy sessions around long enough for the socket. -->
    <session-timeout>600</session-timeout>

    <!-- Leaflet sources for WLeafletMap (console Map view + HUD).
         VERSION-SENSITIVE: Wt >= 4.7 requires these as config properties and
         throws fatally at WLeafletMap construction if unset (the older in-code
         useStyleSheet/require approach no longer suffices). For an offline /
         self-contained deploy, host leaflet.js/leaflet.css under the docroot and
         point these at the local paths. -->
    <properties>
      <property name="leafletJSURL">https://unpkg.com/leaflet@1.9.4/dist/leaflet.js</property>
      <property name="leafletCSSURL">https://unpkg.com/leaflet@1.9.4/dist/leaflet.css</property>
    </properties>
  </application-settings>
</server>
