# Fleet Dispatcher — mobile build/runtime environment.
#
# IMPORTANT: VITE_* values are baked in at BUILD time (npm run build), not read
# at runtime. Set these before building, then deploy dist/. They point the app at
# the API and the realtime bridge by the server's reachable address.
VITE_API_BASE_URL=http://192.168.1.142:5659/api
VITE_REALTIME_URL=ws://192.168.1.142:8765
