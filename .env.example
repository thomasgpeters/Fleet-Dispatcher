# Fleet Dispatcher — environment configuration
# Copy to .env and adjust as needed. All ports are configurable.

# --- PostgreSQL (backend) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fleet_dispatcher
DB_USER=fleet
DB_PASSWORD=fleet

# SQLAlchemy / psql connection string (derived from the above).
DATABASE_URL=postgresql://fleet:fleet@localhost:5432/fleet_dispatcher

# --- ApiLogicServer (middleware) ---
API_HOST=0.0.0.0
API_PORT=5659

# --- Mobile portal (Vite dev server) ---
# Base URL the mobile app uses to reach the JSON:API.
VITE_API_BASE_URL=http://localhost:5659/api
