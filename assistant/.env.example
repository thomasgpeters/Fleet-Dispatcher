# Hey Dispatch assistant service — copy to .env and fill in.

# --- AI provider (pick one) --------------------------------------------------
# The backend admin chooses the AI service and supplies its credential.
#   anthropic : hosted Claude (default) — needs ANTHROPIC_API_KEY
#   openai    : hosted OpenAI           — needs OPENAI_API_KEY
#   ollama    : local models            — needs OLLAMA_BASE_URL (no real key)
ASSISTANT_PROVIDER=anthropic

# Anthropic (when ASSISTANT_PROVIDER=anthropic). The SDK reads this from env.
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (when ASSISTANT_PROVIDER=openai).
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=                 # optional: OpenAI-compatible gateway

# Ollama (when ASSISTANT_PROVIDER=ollama). Local, OpenAI-compatible endpoint.
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Model + reasoning. ASSISTANT_MODEL defaults per provider
# (anthropic=claude-opus-4-8, openai=gpt-4o, ollama=llama3.1); override here.
# ASSISTANT_MODEL=
ASSISTANT_EFFORT=low            # low|medium|high|max — Anthropic only; snappier voice loop
ASSISTANT_MAX_TOKENS=1024
ASSISTANT_MAX_TOOL_TURNS=5

# --- Downstream services -----------------------------------------------------
FLEET_API_BASE_URL=http://localhost:5659/api   # ApiLogicServer JSON:API (messaging)
GIS_BASE_URL=http://localhost:5701             # geospatial endpoint
HERE_API_KEY=                                  # truck routing (optional; falls back to estimates)

# --- This service ------------------------------------------------------------
ASSISTANT_PORT=5710
