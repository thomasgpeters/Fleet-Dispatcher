# Fleet Dispatcher — Hey Dispatch assistant: systemd EnvironmentFile.
# Copy to /etc/fleet-dispatcher/assistant.env and `chmod 600` — it holds a secret.
# Format: KEY=value, one per line (no `export`, no quotes needed by systemd).

# --- AI provider (pick one) ---
# anthropic (default) | openai | ollama
ASSISTANT_PROVIDER=anthropic

# Supply the credential for the chosen provider:
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Optional model / tuning overrides (defaults per provider).
# ASSISTANT_MODEL=
ASSISTANT_EFFORT=low
ASSISTANT_MAX_TOKENS=1024
ASSISTANT_MAX_TOOL_TURNS=5

# --- Downstream services ---
FLEET_API_BASE_URL=http://localhost:5659/api
GIS_BASE_URL=http://localhost:5701
HERE_API_KEY=

# --- This service ---
ASSISTANT_PORT=5710
