# Realtime WebSocket bridge — configuration (copy to .env).

# --- Kafka (consume the topics ALS produces to) ---
# ALS uses KAFKA_SERVER; either name works here.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=fleet-realtime-bridge
KAFKA_AUTO_OFFSET_RESET=latest
# Topics to subscribe to (optional — defaults to every topic in the route map
# below). One topic per purpose/row type.
# KAFKA_TOPICS=message,position
#
# Topic routing (optional override; JSON). Maps each topic to the WebSocket keys
# clients subscribe to. Unknown topics still work (broadcast on their own name),
# so you usually only set this to add scopes for a new purpose.
#   KAFKA_TOPIC_ROUTES={"message":{"broadcast":"messages","scopes":[{"prefix":"channel","field":"channel_id"}]},"load":{"broadcast":"loads","scopes":[{"prefix":"driver","field":"driver_id"}]}}

# --- WebSocket server ---
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8765
WS_PING_INTERVAL=20
WS_PING_TIMEOUT=20

# --- Auth (reuse the ALS JWT secret; HS256) ---
FLEET_JWT_SECRET=change-me-to-the-ALS-secret
FLEET_JWT_ALGORITHM=HS256
# Set false ONLY for local dev without tokens.
BRIDGE_AUTH_REQUIRED=true
