# Fleet Dispatcher — geospatial endpoint environment.
# Connects as fleet_gis (owns the gis views; search_path = gis, fleet, public).
GIS_DATABASE_URL=postgresql://fleet_gis:fleet_gis@localhost:5432/fleet_dispatcher
GIS_PORT=5701

# Route recompute (writes fleet.route) — uses the fleet app role (write on fleet).
FLEET_DATABASE_URL=postgresql://fleet:fleet@localhost:5432/fleet_dispatcher
ROUTING_AVG_MPH=50
# Auto-recompute consumer (optional; runs only if Kafka is configured).
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
RECOMPUTE_TOPICS=waypoint,trip
