# --- Environment / secrets ---
# Real config (Kafka brokers/creds, JWT secret, DB URLs) lives in *.env files and
# stays out of git. Only *.env.example templates (placeholders) are committed.
.env
*.env
!*.env.example
*.local

# --- Python (domain + middleware) ---
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- Node / mobile portal ---
node_modules/
portals/mobile/dist/
portals/mobile/.vite/
*.log

# --- Capacitor native ---
portals/mobile/ios/
portals/mobile/android/

# --- C++ / desktop portal ---
portals/dispatcher-desktop/build/
*.o
*.obj

# --- Editors / OS ---
.idea/
.vscode/
.DS_Store
